APP_NAME="Blood Cell Detection API"
HOST=0.0.0.0
PORT=8000
DEBUG=false

MODEL_WEIGHTS_PATH=models/weights/best.pt
CONFIDENCE_THRESHOLD=0.25
IOU_THRESHOLD=0.45
IMAGE_SIZE=640
DEVICE=cpu

MAX_UPLOAD_SIZE_MB=10

# Optional OpenAI report enhancement. Only used when calling:
# POST /api/v1/analyze?enhance_with_ai=true
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_TIMEOUT_SECONDS=8
